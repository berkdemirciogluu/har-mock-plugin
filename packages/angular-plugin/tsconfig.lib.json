{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declarationDir": "dist/types",
    "inlineSources": true,
    "sourceRoot": "/"
  },
  "angularCompilerOptions": {
    "skipTemplateCodegen": true,
    "strictMetadataEmit": true,
    "enableResourceInlining": true
  },
  "exclude": ["src/**/*.spec.ts", "node_modules"]
}
