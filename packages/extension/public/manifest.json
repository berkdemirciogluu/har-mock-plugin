{
  "manifest_version": 3,
  "name": "HAR Mock Plugin",
  "version": "0.0.1",
  "description": "Intercept and replay HTTP requests from HAR files",
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"]
}
