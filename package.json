{
  "name": "har-mock-plugin-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:core": "yarn workspace @har-mock/core build",
    "build:extension": "yarn workspace @har-mock/extension build",
    "build:plugin": "yarn workspace har-mock-plugin build",
    "test:all": "yarn workspaces run test:coverage",
    "lint:all": "eslint \"packages/*/src/**/*.ts\" --max-warnings 0",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,html,css,json}\"",
    "format:write": "prettier --write \"packages/*/src/**/*.{ts,html,css,json}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
